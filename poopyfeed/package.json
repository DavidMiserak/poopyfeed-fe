{
  "name": "poopyfeed",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "serve:ssr:poopyfeed": "node dist/poopyfeed/server/server.mjs",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write \"src/**/*.{ts,html,css,json}\" \"e2e/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,json}\" \"e2e/**/*.ts\"",
    "analyze:children": "ng build --configuration production --stats-json && npx source-map-explorer \"dist/poopyfeed/browser/*.js\""
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-server": "^21.1.0",
    "@angular/pwa": "^21.1.3",
    "@angular/router": "^21.1.0",
    "@angular/service-worker": "^21.1.0",
    "@angular/ssr": "21.1.3",
    "chart.js": "^4.5.1",
    "compression": "^1.8.1",
    "express": "^5.1.0",
    "firebase": "^11.8.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.3",
    "@angular/cli": "^21.1.3",
    "@angular/compiler-cli": "^21.1.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@vitest/coverage-v8": "^4.0.18",
    "angular-eslint": "21.2.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^27.1.0",
    "lighthouse": "^13.0.3",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "puppeteer": "^24.37.5",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.50.1",
    "vitest": "^4.0.8",
    "zone.js": "^0.16.1"
  }
}
