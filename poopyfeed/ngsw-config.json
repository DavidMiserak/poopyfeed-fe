{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.svg",
          "/index.csr.html",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/main-*.js",
          "/polyfills-*.js",
          "/runtime-*.js",
          "/fonts/*.woff2"
        ]
      }
    },
    {
      "name": "app-lazy",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/chunk-*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/icons/**",
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-readonly-lists",
      "urls": [
        "/api/v1/children/",
        "/api/v1/children/**/feedings/",
        "/api/v1/children/**/diapers/",
        "/api/v1/children/**/naps/",
        "/api/v1/children/**/shares/",
        "/api/v1/children/**/invites/",
        "/api/v1/analytics/children/**/timeline/"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 100,
        "maxAge": "10m",
        "refreshAhead": "2m"
      }
    }
  ],
  "navigationUrls": [
    "/**",
    "!/api/**",
    "!/admin/**",
    "!/static/**",
    "!/media/**",
    "!/**/*.*",
    "!/**/*__*",
    "!/**/*__*/**"
  ]
}
